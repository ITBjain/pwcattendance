<?xml version="1.0" encoding="utf-8"?>
<!--
  NuGet configuration for pwcattendance (.NET 10.0 ASP.NET Core API).

  Explicitly declares the official NuGet.org v3 feed as the sole package
  source. This ensures a clean, reliable restore and prevents resolution
  failures for transitive dependencies such as
  Microsoft.CodeAnalysis.Analyzers when the local package cache is stale
  or incomplete.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
